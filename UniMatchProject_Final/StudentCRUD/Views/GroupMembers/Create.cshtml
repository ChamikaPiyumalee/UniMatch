@model StudentCRUD.Models.GroupMembers

<style>
/* Page background */
body {
    background-color: #000;
}

/* Card / form container */
.dark-card {
    background-color: #121212; /* light black */
    color: #fff;
    border-radius: 12px;
}

/* Labels */
.dark-card .form-label {
    color: #ccc;
}

/* Inputs & dropdowns */
.dark-card .form-control,
.dark-card .form-select {
    background-color: #1e1e1e;
    color: #fff;
    border: 1px solid #333;
}

/* Focus effect */
.dark-card .form-control:focus,
.dark-card .form-select:focus {
    background-color: #1e1e1e;
    color: #fff;
    border-color: #666;
    box-shadow: none;
}

/* Checkbox */
.dark-card .form-check-input {
    background-color: #1e1e1e;
    border: 1px solid #555;
}

.dark-card .form-check-input:checked {
    background-color: #fff;
    border-color: #fff;
}

/* Buttons */
.dark-card .btn-dark {
    background-color: #fff;
    color: #000;
    border: none;
}

.dark-card .btn-dark:hover {
    background-color: #ccc;
}
</style>
<div class="container mt-5">
    <h2 class="mb-4 text-white">Create Group Member</h2>

    <form method="post" class="p-4 shadow dark-card">

        <div class="mb-3">
            <label class="form-label">Group ID</label>
         
            <select name="GroupId" class="form-select" aria-label="Select students" asp-for="GroupId">
                @{
                    var students = ViewBag.GroupName as List<SelectListItem> ?? new List<SelectListItem>();
                }
                @foreach (var s in students)
                {
                    <option value="@s.Value">@s.Text</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Student ID</label>
           
            <select name="StudentId" class="form-select" aria-label="Select students" asp-for="StudentId">
                @{
                    var students = ViewBag.Students as List<SelectListItem> ?? new List<SelectListItem>();
                }
                @foreach (var s in students)
                {
                    <option value="@s.Value">@s.Text</option>
                }
            </select>
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsLeader" class="form-check-input" />
            <label class="form-check-label">Is Leader</label>
        </div>

        <button type="submit" class="btn btn-dark">Save</button>
        <a href="/GroupMembers" class="btn btn-secondary">Back</a>

    </form>
</div>