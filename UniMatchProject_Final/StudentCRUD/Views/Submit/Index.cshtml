@using StudentCRUD.ViewModels


@model List<SubmitDetailsViewModel>

<style>
    body {
        background: linear-gradient(135deg, #1f1f1f, #2c2c2c);
        color: #fff;
    }

    .card-custom {
        background: #2b2b2b;
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.4);
    }

    .table thead {
        background-color: #000;
        color: #fff;
    }

    .table td, .table th {
        vertical-align: middle;
        color: #fff;
    }

    .btn-custom {
        border-radius: 8px;
        padding: 5px 12px;
    }
</style>
@{
    var userId = Context.Session.GetInt32("UserId");
    var isStudent = Context.Session.GetInt32("IsStudent");
    var isStaff = Context.Session.GetInt32("IsStaff");
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">Submit</h2>
        @if (isStudent == 1)
        {
                    <a href="/Submit/Create" class="btn btn-success btn-custom">
            + Add New
        </a>
        }

    </div>

    <div class="card card-custom">
        <div class="table-responsive">
            <table class="table table-dark table-hover table-bordered text-center align-middle mb-0">

                <thead>
                    <tr>
                        <th>Group Name</th>
                        <th>Project Description</th>
                        <th>Project Name</th>
                        <th>Submitted Time</th>
                        <th>Supervisor</th>
                        <th>Members Count</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>@s.GroupName</td>
                            <td>@s.ProjectDescription</td>
                            <td>@s.ProjectName</td>
                            <td>@s.SubmittedTime</td>
                            <td>@s.SupervisorName</td>
                            <td>@s.Count</td>
                            <td>
                                @if (isStaff == 1 )
                                {
                                <a href="/Submit/Edit/@s.GroupId" class="btn btn-warning btn-sm btn-custom">Confirm</a>
                                }
                                @if (isStudent == 1)
                                {
                                <a href="/GroupName/Delete/@s.GroupId" class="btn btn-danger btn-sm btn-custom">Delete</a>
                                }

                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>

</div>