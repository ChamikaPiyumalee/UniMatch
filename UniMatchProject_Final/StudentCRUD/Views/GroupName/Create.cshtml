@model StudentCRUD.Models.GroupName

<style>
    /* Page background */
    body {
        background-color: #000;
    }

    /* Card / form container */
    .dark-card {
        background-color: #121212; /* light black */
        color: #fff;
        border-radius: 12px;
    }

        /* Labels */
        .dark-card .form-label {
            color: #ccc;
        }

        /* Inputs & dropdowns */
        .dark-card .form-control,
        .dark-card .form-select {
            background-color: #1e1e1e;
            color: #fff;
            border: 1px solid #333;
        }

            /* Focus effect */
            .dark-card .form-control:focus,
            .dark-card .form-select:focus {
                background-color: #1e1e1e;
                color: #fff;
                border-color: #666;
                box-shadow: none;
            }

        /* Checkbox */
        .dark-card .form-check-input {
            background-color: #1e1e1e;
            border: 1px solid #555;
        }

            .dark-card .form-check-input:checked {
                background-color: #fff;
                border-color: #fff;
            }

        /* Buttons */
        .dark-card .btn-dark {
            background-color: #fff;
            color: #000;
            border: none;
        }

            .dark-card .btn-dark:hover {
                background-color: #ccc;
            }
</style>

<div class="container mt-5">
    <h2 class="mb-4">Create Group Name</h2>
    <form method="post" class="p-4 shadow rounded dark-card">

     

        <div class="mb-3">
            <label class="form-label">Group Name</label>
            <input asp-for="G_Name" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Number Of Members</label>
            <input asp-for="NumOfMembers" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Module ID</label>
 
            <select name="ModuleId" class="form-select" aria-label="Select students" asp-for="ModuleId">
                @{
                    var students = ViewBag.Modules as List<SelectListItem> ?? new List<SelectListItem>();
                }
                @foreach (var s in students)
                {
                    <option value="@s.Value">@s.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Project Name</label>
            <input asp-for="ProjectName" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Project Description</label>
            <input asp-for="ProjectDescription" class="form-control" />
        </div>
        <button type="submit" class="btn btn-dark">Save</button>
        <a href="/GroupName" class="btn btn-secondary">Back</a>
    


</form>

</div>