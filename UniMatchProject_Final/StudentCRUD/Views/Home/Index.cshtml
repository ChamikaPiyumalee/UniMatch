
@{
    ViewData["Title"] = "Home Page";

    var userId = Context.Session.GetInt32("UserId");
    var isStudent = Context.Session.GetInt32("IsStudent");
    var isStaff = Context.Session.GetInt32("IsStaff");
}

<style>
    body {
        /* background: linear-gradient(135deg, #1f1f1f, #2c2c2c);
        color: #fff; */
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
    }

    .home-container {
        text-align: center;
        padding: 50px 20px;
    }



    .welcome-card {
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(10px);
        padding: 30px;
        border-radius: 15px;
        max-width: 600px;
        margin: auto;
        box-shadow: 0 8px 20px rgba(0,0,0,0.4);
        color: #fff;
    }

    .profile-img {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        margin-bottom: 15px;
        border: 3px solid #28a745;
    }

    .info-box {
        margin-top: 15px;
        font-size: 16px;
    }

    .badge {
        padding: 6px 12px;
        border-radius: 8px;
        margin: 5px;
        display: inline-block;
    }

    .student {
        background: #007bff;
    }

    .staff {
        background: #28a745;
    }
</style>

<div class="home-container">

    <div class="welcome-card">

        <!-- Image -->
        <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
             alt="User Image"
             class="profile-img" />

        <!-- Welcome -->
        <h2>Welcome</h2>

        <div class="info-box">
            @if (isStudent == 1)
            {
            <span class="badge student">Student</span>
            }

            @if (isStaff == 1)
            {
            <span class="badge staff">Staff</span>
            }
        </div>



    </div>

</div>
